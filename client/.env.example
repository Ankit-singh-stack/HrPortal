# Backend API URL (leave empty for local development, set to backend URL for production)
# For production on Render, set this to your backend server URL
# Example: VITE_API_URL=https://your-backend-url.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Copy server/.env value of RAZORPAY_KEY_ID here as VITE_RAZORPAY_KEY_ID (must match for signature verification + real payments).
# VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
